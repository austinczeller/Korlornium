filters:
  and:
    - '!file.inFolder("z_Assests")'
formulas:
  Untitled: ""
views:
  - type: table
    name: Table
    order:
      - file.name
      - Type
      - file.mtime
    sort:
      - property: file.mtime
        direction: ASC
    limit: 5
    columnSize:
      file.name: 270
      note.Type: 284
