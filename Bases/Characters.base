        direction: ASC
      - property: Organizations
        direction: ASC
      - property: file.mtime
        direction: DESC
      - property: file.name
        direction: ASC
      - property: Antagonisic
        direction: ASC
    columnSize:
      file.name: 171
      note.Location: 278
      note.Organizations: 128
  - type: table
    name: The Salty Bitches
    filters:
      or:
        - Organizations.contains(link("The Salty Bitches"))
    order:
