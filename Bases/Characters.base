      file.name: 171
      note.Location: 278
      note.Organizations: 128
  - type: table
    name: The Scar
    filters:
      and:
        - Location.contains(link("The Scar"))
    order:
      - file.name
      - Location
      - Organizations
      - Alive
      - Species
      - Antagonisic
    sort:
