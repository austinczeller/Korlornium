filters:
  and:
    - Type == "Session"
views:
  - type: table
    name: Table
    order:
      - file.name
      - Date
      - Location
    sort:
      - property: IGN-Date
        direction: ASC
      - property: file.name
        direction: ASC
      - property: date
        direction: DESC
    columnSize:
      note.date: 125
