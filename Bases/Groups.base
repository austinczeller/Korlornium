filters:
  and:
    - Type == "Group"
formulas:
  Number of members: this.file.links
  Members: |
    if(Type = NPC, if(Organizations = [[]], list))
properties:
  file.name:
    displayName: Facton
views:
  - type: table
    name: Table
    order:
      - file.name
      - Location
    sort: []
    columnSize:
      file.name: 222
