      "template": "z_Assets/Templates/NPC Template.md"
    },
    {
      "folder": "History",
      "template": "z_Assests/Templates/History Template.md"
    },
    {
      "folder": "Organizations",
      "template": "z_Assests/Templates/Group Template.md"
    },
    {
      "folder": "Calendar",
      "template": "z_Assests/Templates/History Template.md"
    },
    {
      "folder": "Things and Objects",
      "template": "z_Assests/Templates/Item Template.md"
    }
